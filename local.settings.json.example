{
  "IsEncrypted": false,
  "Values": {
    "AzureWebJobsStorage": "UseDevelopmentStorage=true",
    "FUNCTIONS_WORKER_RUNTIME": "python",
    "FMP_API_KEY": "<your-financial-modeling-prep-api-key>",
    "AZURE_STORAGE_CONNECTION_STRING": "DefaultEndpointsProtocol=https;AccountName=<name>;AccountKey=<key>;EndpointSuffix=core.windows.net",
    "BLOB_CONTAINER_RAW": "financial-raw",
    "OPENAI_API_KEY": "<your-openai-api-key>",
    "CHROMA_API_KEY": "<your-chroma-cloud-api-key>",
    "CHROMA_TENANT": "<your-chroma-tenant-id>",
    "CHROMA_DATABASE": "<your-chroma-database-name>",
    "CHROMA_COLLECTION": "financial_docs"
  }
}
